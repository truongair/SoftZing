{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SoftZing",
  "version": "1.0.0",
  "identifier": "com.softzingapp.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SoftZing",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "center": true,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
